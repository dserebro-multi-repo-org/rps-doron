{
    "name": "johnamadeo/rps",
    "description": "Rock Paper Scissors REST API",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "symfony/framework-bundle": "^7.4",
        "symfony/string": "^7.4",
        "symfony/yaml": "^7.4",
        "symfony/dotenv": "^7.4",
        "john-mc-dogfood/canonical-logs": "^1.0"
    },
    "require-dev": {
        "symfony/debug-bundle": "^7.4"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/acidic-clam/canonical-logs"
        }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "symfony": {
            "allow-contrib": false
        }
    }
}
